# Auth credentials — override via Kubernetes Secret (SealedSecret in production)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Upstream Fluidd UI target
UPSTREAM_HOST=192.168.1.177
UPSTREAM_PORT=4409

# Moonraker WebSocket/API port (proxied at /moonraker path)
MOONRAKER_PORT=7125

# Session secret — use a long random string in production
SESSION_SECRET=replace-with-a-long-random-secret-string

# Server port inside the container
PORT=3000

# Set to "true" behind a TLS-terminating ingress so session cookies are Secure
TRUST_PROXY=true
